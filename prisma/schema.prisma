generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// ============ 用户系统 ============

model User {
  id        String   @id @default(cuid())
  phone     String   @unique
  email     String?  @unique
  name      String
  password  String?
  role      String   @default("user")
  avatar    String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  servers          Server[]
  apiHistory       ApiHistory[]
  commandHistory   CommandHistory[]
  sessionSnapshots SessionSnapshot[]
  scripts          Script[]
  configFiles      ConfigFile[]
  settings         UserSettings?
  alertEvents      AlertEvent[]
  configBaselines  ConfigBaseline[]
  alertRules       AlertRule[]
  auditLogs        AuditLog[]
  certMonitors     CertMonitor[]
  runbooks         Runbook[]
  knowledgeEntries KnowledgeEntry[]
  changeRecords    ChangeRecord[]
  messageReads     MessageRead[]
  feedbacks        Feedback[]
}

// ============ 服务器管理 ============

model Server {
  id         String   @id @default(cuid())
  userId     String
  name       String
  host       String
  port       Int      @default(22)
  username   String
  password   String?
  privateKey String?
  tags       String?  @default("[]")
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  user            User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  commandHistory  CommandHistory[]
  snapshots       SessionSnapshot[]
  alertEvents     AlertEvent[]
  configSnapshots ConfigSnapshot[]
}

// ============ API 测试历史 ============

model ApiHistory {
  id        String   @id @default(cuid())
  userId    String
  name      String
  method    String
  url       String
  headers   String   @default("[]")
  body      String?
  status    Int?
  time      Int?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ============ 终端命令历史 ============

model CommandHistory {
  id        String   @id @default(cuid())
  userId    String
  serverId  String?
  command   String
  output    String?
  createdAt DateTime @default(now())

  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  server Server? @relation(fields: [serverId], references: [id], onDelete: SetNull)
}

// ============ 会话快照 ============

model SessionSnapshot {
  id        String   @id @default(cuid())
  userId    String
  serverId  String?
  name      String
  commands  String   @default("[]")
  createdAt DateTime @default(now())

  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  server Server? @relation(fields: [serverId], references: [id], onDelete: SetNull)
}

// ============ 脚本库 ============

model Script {
  id        String   @id @default(cuid())
  userId    String
  title     String
  content   String
  language  String
  source    String   @default("manual")
  tags      String   @default("[]")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ============ 配置文件 ============

model ConfigFile {
  id        String   @id @default(cuid())
  userId    String
  title     String
  content   String
  type      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ============ 用户设置 ============

model UserSettings {
  id                 String @id @default(cuid())
  userId             String @unique
  theme              String @default("light")
  monitorInterval    Int    @default(5000)
  terminalFontSize   Int    @default(14)
  terminalFontFamily String @default("Menlo, Monaco, \"Courier New\", monospace")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ============ 告警事件 ============

model AlertEvent {
  id        String   @id @default(cuid())
  userId    String
  serverId  String?
  type      String
  severity  String
  title     String
  message   String
  resolved  Boolean  @default(false)
  metadata  String?  @default("{}")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  server Server? @relation(fields: [serverId], references: [id], onDelete: SetNull)
}

// ============ 配置快照（漂移检测） ============

model ConfigSnapshot {
  id        String   @id @default(cuid())
  serverId  String
  filePath  String
  content   String
  hash      String
  createdAt DateTime @default(now())

  server Server @relation(fields: [serverId], references: [id], onDelete: Cascade)
}

// ============ Runbook ============

model Runbook {
  id            String   @id @default(cuid())
  userId        String
  title         String
  description   String?
  triggerType   String
  triggerConfig String   @default("{}")
  steps         String   @default("[]")
  enabled       Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ============ 知识图谱 KEDB ============

model KnowledgeEntry {
  id         String   @id @default(cuid())
  userId     String
  title      String
  symptom    String
  cause      String
  solution   String
  tags       String   @default("[]")
  severity   String   @default("medium")
  usageCount Int      @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ============ 变更记录 ============

model ChangeRecord {
  id          String    @id @default(cuid())
  userId      String
  title       String
  description String?
  type        String
  riskLevel   String    @default("low")
  status      String    @default("pending")
  serverIds   String    @default("[]")
  steps       String    @default("[]")
  result      String?
  approvedBy  String?
  approvedAt  DateTime?
  executedAt  DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ============ 系统消息 ============

model Message {
  id        String   @id @default(cuid())
  title     String
  content   String
  type      String   @default("info")
  createdAt DateTime @default(now())

  reads MessageRead[]
}

model MessageRead {
  id        String   @id @default(cuid())
  messageId String
  userId    String
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  message Message @relation(fields: [messageId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([messageId, userId])
}

// ============ 用户反馈 ============

model Feedback {
  id        String   @id @default(cuid())
  userId    String
  type      String   @default("suggestion")
  title     String
  content   String
  status    String   @default("pending")
  reply     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ============ 配置基线（本地漂移检测） ============

model ConfigBaseline {
  id        String   @id @default(cuid())
  userId    String
  filePath  String
  fileName  String
  hash      String
  content   String
  enabled   Boolean  @default(true)
  lastCheck DateTime @default(now())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  drifts ConfigDrift[]

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ============ 配置漂移记录 ============

model ConfigDrift {
  id           String   @id @default(cuid())
  baselineId   String
  oldHash      String
  newHash      String
  oldContent   String
  newContent   String
  detectedAt   DateTime @default(now())

  baseline ConfigBaseline @relation(fields: [baselineId], references: [id], onDelete: Cascade)
}

// ============ 告警规则 ============

model AlertRule {
  id        String   @id @default(cuid())
  userId    String
  name      String
  type      String
  condition String
  threshold Float
  severity  String   @default("warning")
  enabled   Boolean  @default(true)
  cooldown  Int      @default(300)
  lastFired DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ============ 审计日志 ============

model AuditLog {
  id        String   @id @default(cuid())
  userId    String
  action    String
  resource  String
  detail    String?
  ip        String?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ============ 证书监控 ============

model CertMonitor {
  id          String    @id @default(cuid())
  userId      String
  domain      String
  port        Int       @default(443)
  label       String?
  lastCheck   DateTime?
  lastStatus  String?
  issuer      String?
  validFrom   DateTime?
  validTo     DateTime?
  daysLeft    Int?
  enabled     Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ============ 短信验证码 ============

model SmsCode {
  id        String   @id @default(cuid())
  phone     String
  code      String
  purpose   String   @default("login")
  used      Boolean  @default(false)
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([phone, purpose])
}
