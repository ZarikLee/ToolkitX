$ sed 's/old/new/g' file                    # 替换所有匹配
$ sed -i 's/old/new/g' file                 # 直接修改文件
$ sed -i.bak 's/old/new/g' file             # 修改前备份
$ sed '3d' file                             # 删除第3行
$ sed '/pattern/d' file                     # 删除匹配行
$ sed '2a\new line' file                    # 在第2行后插入
$ sed '2i\new line' file                    # 在第2行前插入
$ sed -n '5,10p' file                       # 打印第5-10行
$ sed 's/^/    /' file                      # 每行前加4个空格`,
          language: "bash",
