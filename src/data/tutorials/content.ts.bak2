$ grep -c "error" file                       # 统计匹配行数
$ grep -v "debug" file                       # 反向匹配（排除）
$ grep -l "pattern" *.log                    # 只显示文件名
$ grep -A 3 "error" file                     # 显示匹配行及后3行
$ grep -B 2 "error" file                     # 显示匹配行及前2行
$ grep -E "err|warn|crit" file               # 使用扩展正则
