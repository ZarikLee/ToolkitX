$ sort -n file                  # 按数值排序
$ sort -k2 file                 # 按第2列排序
$ sort -t: -k3 -n /etc/passwd   # 指定分隔符和列

$ sort file | uniq              # 去重（需先排序）
$ sort file | uniq -c           # 去重并计数
$ sort file | uniq -d           # 只显示重复行
$ sort file | sort | uniq -c | sort -rn  # 统计词频`,
