          code: `package main

import "fmt"

// 函数定义
func greet(name string) string {
    return "你好，" + name + "！"
}

// 多返回值
func divide(a, b float64) (float64, error) {
    if b == 0 {
        return 0, fmt.Errorf("除数不能为零")
    }
    return a / b, nil
}

func main() {
    fmt.Println(greet("Go 开发者"))

    result, err := divide(10, 3)
    if err != nil {
        fmt.Println("错误:", err)
    } else {
        fmt.Printf("结果: %.2f\\n", result)
    }
}`,
          language: "go",
