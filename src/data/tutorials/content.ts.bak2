$ command 2> file              # 标准错误重定向
$ command &> file              # 所有输出重定向
$ command < file               # 标准输入重定向

$ cat file | grep "error" | wc -l    # 管道组合
$ ps aux | grep nginx | grep -v grep # 查找nginx进程
$ cat access.log | awk '{print $1}' | sort | uniq -c | sort -rn | head -10  # 统计IP`,
