// 结构体定义
struct Student {
    char name[50];
    int age;
    float score;
};

// 函数定义
void printStudent(struct Student *s) {
    printf("姓名: %s, 年龄: %d, 成绩: %.1f\\n",
           s->name, s->age, s->score);
}

int main() {
    // 数组
    int numbers[] = {1, 2, 3, 4, 5};
    int sum = 0;

    for (int i = 0; i < 5; i++) {
        sum += numbers[i];
    }
    printf("数组总和: %d\\n", sum);

    // 指针
    int x = 42;
    int *ptr = &x;
    printf("x 的地址: %p, 值: %d\\n", (void*)ptr, *ptr);

    // 结构体
    struct Student stu = {"张三", 20, 95.5};
    printStudent(&stu);

    return 0;
}`,
